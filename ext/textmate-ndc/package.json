{
  "name": "ndc-syntax",
  "displayName": "Andy C++ (ndc)",
  "description": "Syntax highlighting for the Andy C++ (.ndc) language",
  "version": "0.1.0",
  "publisher": "timfennis",
  "license": "MIT",
  "engines": {
    "vscode": "^1.0.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ndc",
        "aliases": [
          "Andy C++",
          "ndc"
        ],
        "extensions": [
          ".ndc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ndc",
        "scopeName": "source.ndc",
        "path": "./syntaxes/ndc.tmLanguage.json"
      }
    ]
  }
}
