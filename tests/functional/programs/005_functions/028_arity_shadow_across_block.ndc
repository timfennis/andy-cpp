// Inner block shadows only the same-arity overload; different arity remains accessible.
fn foo(a) { "one:" ++ a }
fn foo(a, b) { "two:" ++ a ++ "," ++ b }

{
    fn foo(a) { "inner:" ++ a }
    assert_eq(foo("x"), "inner:x");
    assert_eq(foo("x", "y"), "two:x,y");
}

// After the block, the outer 1-arg version is restored
assert_eq(foo("x"), "one:x");
assert_eq(foo("x", "y"), "two:x,y");
