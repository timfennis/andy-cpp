// Basic 2-combinations of a list.
assert_eq(combinations([1, 2, 3], 2).list(), [(1, 2), (1, 3), (2, 3)]);

// k=0 yields exactly one empty tuple.
assert_eq(combinations([1, 2], 0).list(), [()]);

// k > length yields nothing.
assert_eq(combinations([1, 2], 5).list(), []);

// Works on a tuple source.
assert_eq(combinations((10, 20, 30), 2).list(), [(10, 20), (10, 30), (20, 30)]);

// Works on a map source (order is unspecified, test length only).
assert_eq(combinations(%{"a": 1, "b": 2, "c": 3}, 2).list().len(), 3);

// Lazy: take only the first combination from a large range iterator — the pool
// is never fully materialised.
assert_eq(combinations(1..100, 2).take(1).list(), [(1, 2)]);
