// Tests heap ordering with BigInt, Rational, and Complex values, exercising
// the VM's cross-type OrdValue comparator path.

// MinHeap with BigInts (values outside i64 range)
let h = MinHeap();
h.push(9223372036854775808);   // i64::MAX + 1
h.push(9223372036854775809);
h.push(9223372036854775807);   // i64::MAX (fits in i64)
assert_eq(h.pop, 9223372036854775807);
assert_eq(h.pop, 9223372036854775808);
assert_eq(h.pop, 9223372036854775809);

// MaxHeap with Rationals
let h = MaxHeap();
h.push(5 / 3);
h.push(7 / 4);
h.push(1 / 2);
assert_eq(h.pop, 7 / 4);
assert_eq(h.pop, 5 / 3);
assert_eq(h.pop, 1 / 2);

// MinHeap: mixed int and Rational
let h = MinHeap();
h.push(2);
h.push(3 / 2);   // 1.5
h.push(5 / 2);   // 2.5
assert_eq(h.pop, 3 / 2);
assert_eq(h.pop, 2);
assert_eq(h.pop, 5 / 2);

// MinHeap with Complex (ordered by (re, im) tuple, same as interpreter)
let h = MinHeap();
h.push(3 + 4i);    // (re=3, im=4)
h.push(1 + 0i);    // (re=1, im=0)
h.push(0 + 2i);    // (re=0, im=2) — smallest real part, pops first
assert_eq(h.pop, 0 + 2i);
assert_eq(h.pop, 1 + 0i);
assert_eq(h.pop, 3 + 4i);
