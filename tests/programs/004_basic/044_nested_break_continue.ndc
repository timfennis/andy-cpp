// Break in outer loop, continue in inner loop
let result = 0;
for i in 0..10 {
    for j in 0..10 {
        if j == 3 { continue; }
        result += 1;
    }
    if i == 4 { break; }
}
// i: 0..=4 (5 iterations); j: 0..9 skipping 3 (9 values each) → 5 * 9 = 45
assert_eq(result, 45);

// Continue in outer loop, break in inner loop
let result = 0;
for i in 0..10 {
    if i == 5 { continue; }
    for j in 0..10 {
        if j == 7 { break; }
        result += 1;
    }
}
// i: 0..9 skipping 5 (9 iterations); j: 0..6 (7 values each) → 9 * 7 = 63
assert_eq(result, 63);
