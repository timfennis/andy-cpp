// continue in inner loop must not affect outer loop
let outer_count = 0;
let inner_count = 0;
let i = 0;
while i < 5 {
    i = i+ 1;
    outer_count = outer_count + 1;
    let j = 0;
    while j < 5 {
        j = j + 1;
        if j == 3 { continue; }
        inner_count = inner_count + 1;
    }
}
// If continue leaked to outer, outer_count would be < 5
assert_eq(outer_count, 5);
// j skips 3, so 4 increments per outer iteration: 5 * 4 = 20
assert_eq(inner_count, 20);

// break in inner loop must not affect outer loop
let outer_count = 0;
let inner_count = 0;
let i = 0;
while i < 5 {
    i = i + 1;
    outer_count = outer_count + 1;
    let j = 0;
    while j < 5 {
        j = j + 1;
        if j == 3 { break; }
        inner_count = inner_count + 1;
    }
}
// If break leaked to outer, outer_count would be < 5
assert_eq(outer_count, 5);
// j breaks at 3, so j=1,2 contribute: 2 increments per outer iteration: 5 * 2 = 10
assert_eq(inner_count, 10);
